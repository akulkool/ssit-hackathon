# =============================================================================
# FinSight AI — copy to .env and adjust (do not commit real secrets)
# =============================================================================

# --- Backend (FastAPI) — load in shell or configure on Render/Railway/Docker ---
# Optional: OpenAI for /chat-insights when set; otherwise rule-based replies.
OPENAI_API_KEY=

# Server port (Render/Railway set PORT automatically)
PORT=8000

# Comma-separated browser origins allowed to call the API (CORS).
# Local dev defaults are built-in; add your deployed frontend URL(s), e.g.:
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=

# --- Frontend (Vite) — copy these lines to frontend/.env.local for builds ---
# Leave empty for local dev: requests use /api and Vite proxies to localhost:8000.
# Production: your deployed API origin only (no path, no trailing slash).
# VITE_API_BASE_URL=https://your-api.onrender.com
